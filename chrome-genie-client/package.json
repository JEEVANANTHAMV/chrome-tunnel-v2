{
  "name": "chrome-genie-client",
  "version": "1.0.0",
  "description": "ChromeGenie Client for browser control automation",
  "homepage": "https://github.com/innosynth/chrome-genie-client#readme",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:neu\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:neu": "wait-on http://localhost:3000 && npx @neutralinojs/neu run",
    "start:prod": "npm run build:frontend && npx @neutralinojs/neu run",
    "build:frontend": "cd frontend && npm run build && cd .. && cp -r frontend/out/* resources/ && rm -rf frontend/out",
    "build": "npm run build:frontend && npx @neutralinojs/neu build --release --clean",
    "build:embed": "npm run build:frontend && npx @neutralinojs/neu build --release --clean --embed-resources",
    "download:frp": "node scripts/download-frp-binaries.js",
    "postinstall": "cd frontend && npm install",
    "setup:frp": "node scripts/setup-frp.js"
  },
  "keywords": [],
  "author": {
    "name": "InnoSynth",
    "email": "support@innosynth.com",
    "url": "https://innosynth.com"
  },
  "license": "MIT",
  "devDependencies": {
    "adm-zip": "^0.5.10",
    "concurrently": "^8.2.2",
    "tar": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "shelljs": "^0.8.5"
  }
}
