{
  "name": "chrome-genie-client",
  "version": "1.0.0",
  "description": "ChromeGenie Client for browser control automation",
  "homepage": "https://github.com/innosynth/chrome-genie-client#readme",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:3000 && electron . --no-sandbox",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && npx electron-builder",
    "build:win": "npm run build:frontend && npx electron-builder --win",
    "build:mac": "npm run build:frontend && npx electron-builder --mac",
    "build:linux": "npm run build:frontend && npx electron-builder --linux",
    "download:frp": "node scripts/download-frp-binaries.js",
    "postinstall": "cd frontend && npm install",
    "setup:frp": "node scripts/setup-frp.js"
  },
  "keywords": [],
  "author": {
    "name": "InnoSynth",
    "email": "support@innosynth.com",
    "url": "https://innosynth.com"
  },
  "license": "MIT",
  "devDependencies": {
    "adm-zip": "^0.5.10",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "tar": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-is-dev": "^2.0.0",
    "shelljs": "^0.8.5"
  }
}
